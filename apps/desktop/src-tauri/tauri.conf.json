{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownPlus",
  "version": "0.1.0",
  "identifier": "oss.astraea.markdownplus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MarkdownPlus",
        "width": 1040,
        "height": 680,
        "minWidth": 420,
        "minHeight": 360,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
