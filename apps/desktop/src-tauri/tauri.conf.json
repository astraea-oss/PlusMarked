{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkdownPlus",
  "version": "0.1.0",
  "identifier": "oss.astraea.markdownplus",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "MarkdownPlus",
        "width": 1200,
        "height": 800,
        "minWidth": 860,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}

